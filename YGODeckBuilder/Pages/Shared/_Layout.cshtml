<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YGOCardSearch</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/decksManager.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        .nav-user-chip {
            color: #c0c0e8;
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.95rem;
            padding: 0.3rem 0.75rem;
            background: rgba(125,90,255,0.15);
            border: 1px solid rgba(125,90,255,0.3);
            border-radius: 20px;
            white-space: nowrap;
        }
        .btn-nav-login {
            color: #c0c0e8;
            border: 1px solid rgba(125,90,255,0.45);
            border-radius: 4px;
            padding: 0.25rem 0.9rem;
            font-size: 0.88rem;
            background: transparent;
            transition: background 0.2s;
        }
        .btn-nav-login:hover { background: rgba(125,90,255,0.18); color:#fff; text-decoration:none; }
        .btn-nav-register {
            color: #fff;
            border: 1px solid rgba(125,90,255,0.7);
            border-radius: 4px;
            padding: 0.25rem 0.9rem;
            font-size: 0.88rem;
            background: rgba(91,48,200,0.5);
            transition: background 0.2s;
        }
        .btn-nav-register:hover { background: rgba(91,48,200,0.8); color:#fff; text-decoration:none; }
        .btn-nav-logout {
            color: #a0a0c8;
            border: 1px solid rgba(125,90,255,0.25);
            border-radius: 4px;
            padding: 0.25rem 0.75rem;
            font-size: 0.85rem;
            background: transparent;
            cursor: pointer;
            transition: color 0.2s, border-color 0.2s;
        }
        .btn-nav-logout:hover { color:#e07070; border-color:rgba(200,80,80,0.5); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3 navbar-color">
            <div class="container ml-auto text-center position-relative">
                <a class="navbar-brand d-flex align-items-center" style="color:aliceblue" asp-area="" asp-page="/MainPage">
                    <img src="/images/logo-header-2.jpg" alt="YuGiOh" class="navbar-logo" />
                    <span class="navbar-brand-text">YuGiOh! Deck Builder</span>
                </a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="DecksManager">Decks</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="Favorites">★ Favorites</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="https://github.com/diego-devs/YuGiOhTCG">GitHub</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ml-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item mr-2">
                                <span class="nav-user-chip">👤 @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn-nav-logout">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item mr-1">
                                <a class="btn-nav-register" asp-page="/Account/Register">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-nav-login" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Toast notification container -->
    <div aria-live="polite" aria-atomic="true" style="position:fixed;bottom:1rem;right:1rem;z-index:9999;min-width:250px;">
        <div id="appToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true" data-delay="3500">
            <div class="toast-header">
                <strong class="mr-auto" id="toastTitle">Notification</strong>
                <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="toast-body" id="toastBody"></div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function showToast(message, type) {
            var toast = document.getElementById('appToast');
            var toastBody = document.getElementById('toastBody');
            var toastTitle = document.getElementById('toastTitle');
            toastBody.textContent = message;
            toastTitle.textContent = type === 'error' ? 'Error' : 'Success';
            toast.classList.remove('bg-success', 'bg-danger', 'text-white');
            if (type === 'error') {
                toast.classList.add('bg-danger', 'text-white');
            } else {
                toast.classList.add('bg-success', 'text-white');
            }
            $(toast).toast('show');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
