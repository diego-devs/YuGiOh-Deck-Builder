@page
@model YGODeckBuilder.Pages.GameModel
@{
    ViewData["Title"] = "Duel";
    Layout = "_Layout";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning mt-3">@Model.ErrorMessage</div>
    <a class="btn btn-primary" asp-page="/DecksManager">Back to Decks</a>
}
else
{
<div id="duelRoot">

    <div id="duelTopBar">
        <div class="duel-info">
            <span class="duel-deck-label">Opponent</span>
            <span class="duel-deck-name">@Model.OpponentDeck.DeckName</span>
            <span class="duel-lp" id="lpOpponent">8000</span>
            <button class="lp-btn" data-target="opponent" data-amount="-500">-500</button>
            <button class="lp-btn" data-target="opponent" data-amount="-1000">-1000</button>
            <button class="lp-btn" data-target="opponent" data-amount="500">+500</button>
        </div>
        <div class="duel-phase-display">
            <span class="duel-turn-info">Turn <span id="turnNumber">1</span> — <span id="activePlayerLabel">Your Turn</span></span>
            <span class="duel-phase-name" id="phaseName">Draw Phase</span>
        </div>
        <div class="duel-info">
            <span class="duel-deck-label">You</span>
            <span class="duel-deck-name">@Model.PlayerDeck.DeckName</span>
            <span class="duel-lp" id="lpPlayer">8000</span>
            <button class="lp-btn" data-target="player" data-amount="-500">-500</button>
            <button class="lp-btn" data-target="player" data-amount="-1000">-1000</button>
            <button class="lp-btn" data-target="player" data-amount="500">+500</button>
        </div>
    </div>

    <div id="phaseBar">
        <button class="phase-btn" data-phase="draw">Draw</button>
        <button class="phase-btn" data-phase="standby">Standby</button>
        <button class="phase-btn" data-phase="main1">Main 1</button>
        <button class="phase-btn" data-phase="battle">Battle</button>
        <button class="phase-btn" data-phase="main2">Main 2</button>
        <button class="phase-btn" data-phase="end">End</button>
        <button id="nextPhaseBtn" class="phase-btn primary">Next Phase ▶</button>
        <button id="endTurnBtn" class="phase-btn danger">End Turn ⟲</button>
    </div>

    @* Opponent side *@
    <div class="player-area opponent" data-side="opponent">
        <div class="hand-row hand-opponent">
            <div class="hand" id="hand-opponent"></div>
        </div>
        <div class="board-row">
            <div class="side-zones">
                <div class="zone zone-banished" data-zone="banished" data-side="opponent" title="Banished">B</div>
                <div class="zone zone-graveyard" data-zone="graveyard" data-side="opponent" title="Graveyard">GY</div>
            </div>
            <div class="main-zones">
                <div class="zone-row spell-row">
                    <div class="zone zone-field" data-zone="field" data-side="opponent" title="Field Spell">F</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="opponent" data-index="0">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="opponent" data-index="1">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="opponent" data-index="2">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="opponent" data-index="3">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="opponent" data-index="4">S/T</div>
                </div>
                <div class="zone-row monster-row">
                    <div class="zone zone-extra" data-zone="extra" data-side="opponent" title="Extra Deck">EX</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="opponent" data-index="0">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="opponent" data-index="1">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="opponent" data-index="2">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="opponent" data-index="3">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="opponent" data-index="4">M</div>
                </div>
            </div>
            <div class="side-zones">
                <div class="zone zone-deck" data-zone="deck" data-side="opponent" title="Deck">
                    <span class="deck-count" id="deck-count-opponent">0</span>
                </div>
            </div>
        </div>
    </div>

    @* Player side *@
    <div class="player-area player" data-side="player">
        <div class="board-row">
            <div class="side-zones">
                <div class="zone zone-banished" data-zone="banished" data-side="player" title="Banished">B</div>
                <div class="zone zone-graveyard" data-zone="graveyard" data-side="player" title="Graveyard">GY</div>
            </div>
            <div class="main-zones">
                <div class="zone-row monster-row">
                    <div class="zone zone-monster" data-zone="monster" data-side="player" data-index="0">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="player" data-index="1">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="player" data-index="2">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="player" data-index="3">M</div>
                    <div class="zone zone-monster" data-zone="monster" data-side="player" data-index="4">M</div>
                    <div class="zone zone-extra" data-zone="extra" data-side="player" title="Extra Deck">EX</div>
                </div>
                <div class="zone-row spell-row">
                    <div class="zone zone-spell" data-zone="spell" data-side="player" data-index="0">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="player" data-index="1">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="player" data-index="2">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="player" data-index="3">S/T</div>
                    <div class="zone zone-spell" data-zone="spell" data-side="player" data-index="4">S/T</div>
                    <div class="zone zone-field" data-zone="field" data-side="player" title="Field Spell">F</div>
                </div>
            </div>
            <div class="side-zones">
                <div class="zone zone-deck" data-zone="deck" data-side="player" title="Deck">
                    <span class="deck-count" id="deck-count-player">0</span>
                </div>
            </div>
        </div>
        <div class="hand-row hand-player">
            <div class="hand" id="hand-player"></div>
        </div>
    </div>

    @* Context menu *@
    <div id="cardContextMenu" class="context-menu" style="display:none">
        <ul></ul>
    </div>

    @* Pile viewer modal *@
    <div id="pileViewer" class="modal-backdrop" style="display:none">
        <div class="modal-window">
            <div class="modal-header">
                <h4 id="pileViewerTitle">Pile</h4>
                <button id="pileViewerClose" class="btn btn-sm btn-secondary">Close</button>
            </div>
            <div id="pileViewerContent" class="pile-grid"></div>
        </div>
    </div>

    @* Card preview tooltip *@
    <div id="cardPreview" style="display:none"></div>

    @* Animation layer for flying card clones *@
    <div id="animLayer"></div>

    @* Phase / turn change banner *@
    <div id="phaseBanner"></div>

</div>

<script>
    const PLAYER_DECK = @Json.Serialize(Model.PlayerDeck.MainDeck);
    const PLAYER_EXTRA = @Json.Serialize(Model.PlayerDeck.ExtraDeck);
    const OPPONENT_DECK = @Json.Serialize(Model.OpponentDeck.MainDeck);
    const OPPONENT_EXTRA = @Json.Serialize(Model.OpponentDeck.ExtraDeck);
    const CARD_BACK = '/images/default_card_back.png';

    const PHASES = ['draw','standby','main1','battle','main2','end'];
    const PHASE_LABELS = {
        draw:'Draw Phase',
        standby:'Standby Phase',
        main1:'Main Phase 1',
        battle:'Battle Phase',
        main2:'Main Phase 2',
        end:'End Phase'
    };

    let nextInstanceId = 1;
    function instanceFor(card) {
        return { instanceId: nextInstanceId++, card: card, position: 'atk', faceDown: false };
    }

    function shuffle(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    function makePlayerState(rawDeck, rawExtra) {
        const deck = shuffle(rawDeck.slice()).map(instanceFor);
        const extra = (rawExtra || []).map(instanceFor);
        return {
            deck: deck,
            hand: [],
            extra: extra,
            graveyard: [],
            banished: [],
            field: null,
            monsters: [null, null, null, null, null],
            spells:   [null, null, null, null, null],
            lp: 8000
        };
    }

    const state = {
        player:   makePlayerState(PLAYER_DECK, PLAYER_EXTRA),
        opponent: makePlayerState(OPPONENT_DECK, OPPONENT_EXTRA),
        activeSide: 'player',
        phaseIndex: 0,
        turnNumber: 1,
        firstTurn: true
    };

    function isExtraDeckType(card) {
        if (!card || !card.type) return false;
        const t = card.type.toLowerCase();
        return t.includes('fusion') || t.includes('synchro') || t.includes('xyz') || t.includes('link');
    }

    function isMonsterType(card) {
        if (!card || !card.type) return false;
        return card.type.toLowerCase().includes('monster');
    }

    function isSpellType(card) {
        if (!card || !card.type) return false;
        const t = card.type.toLowerCase();
        return t.includes('spell') || t.includes('trap');
    }

    function isFieldSpell(card) {
        if (!card || !card.type || !card.race) return false;
        return card.type.toLowerCase().includes('spell') && card.race.toLowerCase() === 'field';
    }

    /* ========== Sound (Web Audio synth) ========== */

    let audioCtx = null;
    function getAudioCtx() {
        if (!audioCtx) {
            try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
            catch (e) { audioCtx = null; }
        }
        return audioCtx;
    }

    const SOUND_RECIPES = {
        draw:         { type: 'sine',     freq: 520, freqEnd: 880, dur: 0.18, vol: 0.18 },
        play_monster: { type: 'sawtooth', freq: 220, freqEnd: 110, dur: 0.28, vol: 0.20 },
        play_spell:   { type: 'triangle', freq: 660, freqEnd: 990, dur: 0.20, vol: 0.18 },
        play_field:   { type: 'square',   freq: 330, freqEnd: 165, dur: 0.32, vol: 0.16 },
        to_grave:     { type: 'sine',     freq: 240, freqEnd: 70,  dur: 0.32, vol: 0.20 },
        banish:       { type: 'sawtooth', freq: 880, freqEnd: 220, dur: 0.30, vol: 0.16 },
        to_hand:      { type: 'sine',     freq: 660, freqEnd: 880, dur: 0.18, vol: 0.16 },
        flip:         { type: 'triangle', freq: 520, freqEnd: 720, dur: 0.10, vol: 0.14 },
        set_card:     { type: 'square',   freq: 200, freqEnd: 220, dur: 0.10, vol: 0.12 },
        position:     { type: 'triangle', freq: 440, freqEnd: 440, dur: 0.08, vol: 0.12 },
        shuffle:      { type: 'sawtooth', freq: 120, freqEnd: 60,  dur: 0.40, vol: 0.10, noise: true },
        phase:        { type: 'sine',     freq: 520, freqEnd: 780, dur: 0.25, vol: 0.18 },
        turn:         { type: 'square',   freq: 330, freqEnd: 660, dur: 0.45, vol: 0.18 }
    };

    function playSound(name) {
        const ctx = getAudioCtx();
        if (!ctx) return;
        const r = SOUND_RECIPES[name];
        if (!r) return;
        if (ctx.state === 'suspended') ctx.resume();
        const now = ctx.currentTime;
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = r.type;
        osc.frequency.setValueAtTime(r.freq, now);
        osc.frequency.exponentialRampToValueAtTime(Math.max(20, r.freqEnd), now + r.dur);
        gain.gain.setValueAtTime(0, now);
        gain.gain.linearRampToValueAtTime(r.vol, now + 0.012);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + r.dur);
        osc.connect(gain).connect(ctx.destination);
        osc.start(now);
        osc.stop(now + r.dur + 0.05);

        if (r.noise) {
            const buf = ctx.createBuffer(1, Math.floor(ctx.sampleRate * r.dur), ctx.sampleRate);
            const data = buf.getChannelData(0);
            for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * 0.5;
            const noise = ctx.createBufferSource();
            const ng = ctx.createGain();
            noise.buffer = buf;
            ng.gain.setValueAtTime(0.10, now);
            ng.gain.exponentialRampToValueAtTime(0.0001, now + r.dur);
            noise.connect(ng).connect(ctx.destination);
            noise.start(now);
            noise.stop(now + r.dur);
        }
    }

    /* Unlock audio on first user gesture (browser autoplay policy) */
    function unlockAudio() {
        const ctx = getAudioCtx();
        if (ctx && ctx.state === 'suspended') ctx.resume();
    }
    document.addEventListener('click', unlockAudio, { once: true });
    document.addEventListener('keydown', unlockAudio, { once: true });

    /* ========== Animation ========== */

    let animationsEnabled = true;
    function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

    function findCardEl(side, instanceId) {
        return document.querySelector(`.gcard[data-side="${side}"][data-instance-id="${instanceId}"]`);
    }

    function findZoneEl(side, zone, index) {
        if (index !== null && index !== undefined) {
            return document.querySelector(`.zone[data-side="${side}"][data-zone="${zone}"][data-index="${index}"]`);
        }
        return document.querySelector(`.zone[data-side="${side}"][data-zone="${zone}"]`);
    }

    /* Capture the on-screen visual of a card before its DOM is destroyed by re-render.
       Returns a "handle" to be passed to finishMoveAnim. */
    function startMoveAnim(side, instanceId) {
        if (!animationsEnabled) return null;
        const el = findCardEl(side, instanceId);
        if (!el) {
            // Fallback: caller may pass a zone element via startMoveAnimFromEl
            return null;
        }
        const rect = el.getBoundingClientRect();
        const cloneTemplate = el.cloneNode(true);
        return { srcRect: rect, cloneTemplate, side };
    }

    function startMoveAnimFromEl(srcEl, side) {
        if (!animationsEnabled || !srcEl) return null;
        const rect = srcEl.getBoundingClientRect();
        const cloneTemplate = srcEl.cloneNode(true);
        return { srcRect: rect, cloneTemplate, side };
    }

    /* Fly the cloned card from its captured source position to the destination.
       destLocation: 'monster' | 'spell' | 'field' | 'hand' | 'graveyard' | 'banished' | 'deck' | 'extra'
       For card-shaped destinations (monster/spell/field/hand) we hide the freshly
       rendered card during the flight; for piles we just fly to the zone. */
    function finishMoveAnim(handle, side, instanceId, destLocation, destIndex, durationMs = 350) {
        if (!handle) return;
        let destEl, isCard = false;
        if (destLocation === 'monster' || destLocation === 'spell' || destLocation === 'field' || destLocation === 'hand') {
            destEl = findCardEl(side, instanceId);
            isCard = true;
        } else {
            destEl = findZoneEl(side, destLocation, null);
        }
        if (!destEl) {
            // Nothing to fly to — drop the clone silently.
            return;
        }
        const destRect = destEl.getBoundingClientRect();
        const layer = document.getElementById('animLayer');
        const clone = handle.cloneTemplate;
        clone.style.position = 'fixed';
        clone.style.left = handle.srcRect.left + 'px';
        clone.style.top = handle.srcRect.top + 'px';
        clone.style.width = handle.srcRect.width + 'px';
        clone.style.height = handle.srcRect.height + 'px';
        clone.style.margin = '0';
        clone.style.zIndex = '9999';
        clone.style.pointerEvents = 'none';
        clone.style.transition = `transform ${durationMs}ms cubic-bezier(0.22, 0.61, 0.36, 1), opacity ${durationMs}ms ease`;
        const rot = (handle.side === 'opponent') ? 180 : 0;
        clone.style.transform = `rotate(${rot}deg)`;
        layer.appendChild(clone);
        if (isCard) destEl.style.visibility = 'hidden';
        // Force layout so the initial transform is committed before the next one.
        void clone.offsetHeight;
        const dx = destRect.left - handle.srcRect.left;
        const dy = destRect.top - handle.srcRect.top;
        const sx = handle.srcRect.width  > 0 ? destRect.width  / handle.srcRect.width  : 1;
        const sy = handle.srcRect.height > 0 ? destRect.height / handle.srcRect.height : 1;
        clone.style.transform = `translate(${dx}px, ${dy}px) scale(${sx}, ${sy}) rotate(${rot}deg)`;
        if (!isCard) clone.style.opacity = '0.15';
        let cleaned = false;
        const finish = () => {
            if (cleaned) return;
            cleaned = true;
            if (clone.parentNode) clone.parentNode.removeChild(clone);
            if (isCard && destEl) destEl.style.visibility = '';
        };
        clone.addEventListener('transitionend', finish, { once: true });
        setTimeout(finish, durationMs + 120);
    }

    /* High-level helper: mutate state then animate from inst's current location to dest. */
    function moveCard(side, instanceId, sound, mutate, destLocation, destIndex) {
        const handle = startMoveAnim(side, instanceId);
        if (sound) playSound(sound);
        mutate();
        renderAll();
        finishMoveAnim(handle, side, instanceId, destLocation, destIndex);
    }

    /* ========== Phase banner ========== */

    let bannerTimer = null;
    function showPhaseBanner(text, holdMs = 600) {
        const el = document.getElementById('phaseBanner');
        if (bannerTimer) { clearTimeout(bannerTimer); bannerTimer = null; }
        el.textContent = text;
        el.style.display = 'block';
        // Re-trigger the fade-in even if it's already shown.
        el.classList.remove('show');
        void el.offsetHeight;
        el.classList.add('show');
        bannerTimer = setTimeout(() => {
            el.classList.remove('show');
            bannerTimer = setTimeout(() => { el.style.display = 'none'; bannerTimer = null; }, 220);
        }, holdMs);
    }

    /* ========== Rendering ========== */

    function renderAll() {
        renderHand('player');
        renderHand('opponent');
        renderBoard('player');
        renderBoard('opponent');
        renderCounts();
        renderLP();
        renderPhase();
    }

    function renderLP() {
        document.getElementById('lpPlayer').textContent = state.player.lp;
        document.getElementById('lpOpponent').textContent = state.opponent.lp;
    }

    function renderPhase() {
        document.getElementById('phaseName').textContent = PHASE_LABELS[PHASES[state.phaseIndex]];
        document.getElementById('turnNumber').textContent = state.turnNumber;
        document.getElementById('activePlayerLabel').textContent =
            state.activeSide === 'player' ? 'Your Turn' : "Opponent's Turn";
        document.querySelectorAll('.phase-btn[data-phase]').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.phase === PHASES[state.phaseIndex]);
        });
        document.querySelectorAll('.player-area').forEach(area => {
            area.classList.toggle('active-side', area.dataset.side === state.activeSide);
        });
    }

    function renderCounts() {
        document.getElementById('deck-count-player').textContent = state.player.deck.length;
        document.getElementById('deck-count-opponent').textContent = state.opponent.deck.length;
    }

    function renderHand(side) {
        const handEl = document.getElementById('hand-' + side);
        handEl.innerHTML = '';
        const hand = state[side].hand;
        const showFaceUp = (side === 'player');
        hand.forEach((inst, idx) => {
            const cardEl = buildCardElement(inst, side, 'hand', idx, !showFaceUp);
            cardEl.draggable = (side === 'player');
            cardEl.addEventListener('dragstart', (e) => {
                e.dataTransfer.setData('text/plain', JSON.stringify({
                    side: side, source: 'hand', instanceId: inst.instanceId
                }));
            });
            handEl.appendChild(cardEl);
        });
    }

    function renderBoard(side) {
        const player = state[side];
        // Monster zones
        for (let i = 0; i < 5; i++) renderZoneSlot(side, 'monster', i, player.monsters[i]);
        // Spell zones
        for (let i = 0; i < 5; i++) renderZoneSlot(side, 'spell', i, player.spells[i]);
        // Field zone
        renderZoneSlot(side, 'field', null, player.field);
    }

    function renderZoneSlot(side, zone, index, inst) {
        const selector = index !== null
            ? `.zone[data-side="${side}"][data-zone="${zone}"][data-index="${index}"]`
            : `.zone[data-side="${side}"][data-zone="${zone}"]`;
        const slot = document.querySelector(selector);
        if (!slot) return;
        slot.innerHTML = '';
        if (zone === 'monster' || zone === 'spell' || zone === 'field') {
            slot.appendChild(makeLabel(zone));
        }
        if (inst) {
            const cardEl = buildCardElement(inst, side, zone, index, inst.faceDown);
            if (inst.position === 'def') cardEl.classList.add('defense');
            slot.appendChild(cardEl);
        }
    }

    function makeLabel(zone) {
        const span = document.createElement('span');
        span.className = 'zone-label';
        span.textContent = zone === 'monster' ? 'M' : zone === 'spell' ? 'S/T' : zone === 'field' ? 'F' : '';
        return span;
    }

    function buildCardElement(inst, side, location, index, faceDown) {
        const el = document.createElement('div');
        el.className = 'gcard';
        el.dataset.instanceId = inst.instanceId;
        el.dataset.side = side;
        el.dataset.location = location;
        if (index !== null && index !== undefined) el.dataset.index = index;
        const img = document.createElement('img');
        if (faceDown) {
            img.src = CARD_BACK;
            img.alt = 'face down';
        } else {
            img.src = `/images/${inst.card.id}.jpg`;
            img.alt = inst.card.name || '';
            img.onerror = function() { this.src = CARD_BACK; };
        }
        el.appendChild(img);

        if (!faceDown) {
            el.addEventListener('mouseenter', () => showPreview(inst));
            el.addEventListener('mouseleave', hidePreview);
        }
        el.addEventListener('contextmenu', (e) => {
            e.preventDefault();
            showContextMenu(e, inst, side, location, index);
        });
        return el;
    }

    /* ========== Phase / Turn flow ========== */

    let phaseChanging = false;

    async function setPhase(idx) {
        if (phaseChanging) return;
        phaseChanging = true;
        try {
            state.phaseIndex = idx;
            const phase = PHASES[idx];
            playSound('phase');
            showPhaseBanner(PHASE_LABELS[phase], 550);
            renderAll();
            await delay(450);
            if (phase === 'draw') {
                // Skip draw on first turn for the starting player (standard rule)
                if (!(state.firstTurn && state.turnNumber === 1)) {
                    await drawCard(state.activeSide, 1);
                }
            }
        } finally {
            phaseChanging = false;
        }
    }

    async function nextPhase() {
        if (state.phaseIndex < PHASES.length - 1) {
            await setPhase(state.phaseIndex + 1);
        } else {
            await endTurn();
        }
    }

    async function endTurn() {
        if (phaseChanging) return;
        state.activeSide = state.activeSide === 'player' ? 'opponent' : 'player';
        state.turnNumber++;
        state.firstTurn = false;
        playSound('turn');
        const label = `Turn ${state.turnNumber} — ${state.activeSide === 'player' ? 'Your Turn' : "Opponent's Turn"}`;
        showPhaseBanner(label, 850);
        renderAll();
        await delay(700);
        await setPhase(0);
    }

    /* ========== Drawing ========== */

    async function drawCard(side, n=1, opts={}) {
        const animate = opts.animate !== false;
        const flights = [];
        for (let i = 0; i < n; i++) {
            const player = state[side];
            if (player.deck.length === 0) {
                flashMessage(`${side === 'player' ? 'You have' : 'Opponent has'} no cards left to draw!`);
                break;
            }
            const deckEl = findZoneEl(side, 'deck', null);
            const handle = animate ? startMoveAnimFromEl(deckEl, side) : null;
            const inst = player.deck.shift();
            player.hand.push(inst);
            renderAll();
            if (handle) {
                playSound('draw');
                finishMoveAnim(handle, side, inst.instanceId, 'hand', null, 320);
                flights.push(delay(320));
                if (i < n - 1) await delay(90); // stagger consecutive draws
            }
        }
        await Promise.all(flights);
    }

    function shuffleDeck(side) {
        shuffle(state[side].deck);
        playSound('shuffle');
        flashMessage(`${side === 'player' ? 'Your' : "Opponent's"} deck shuffled.`);
    }

    /* ========== Drag & Drop ========== */

    function setupDropTargets() {
        document.querySelectorAll('.zone').forEach(zone => {
            zone.addEventListener('dragover', (e) => {
                e.preventDefault();
                zone.classList.add('drop-hover');
            });
            zone.addEventListener('dragleave', () => zone.classList.remove('drop-hover'));
            zone.addEventListener('drop', (e) => {
                e.preventDefault();
                zone.classList.remove('drop-hover');
                let payload;
                try { payload = JSON.parse(e.dataTransfer.getData('text/plain')); }
                catch(err) { return; }
                handleDrop(payload, zone);
            });
        });
    }

    function handleDrop(payload, zoneEl) {
        const side = zoneEl.dataset.side;
        const zone = zoneEl.dataset.zone;
        const indexAttr = zoneEl.dataset.index;
        const index = indexAttr !== undefined ? parseInt(indexAttr, 10) : null;

        if (payload.side !== side) {
            flashMessage("You can't drop a card on the opponent's zones.");
            return;
        }

        // Capture the source visual *before* state changes so the flying clone matches.
        const animHandle = startMoveAnim(side, payload.instanceId);

        const player = state[side];
        const inst = takeFromSource(player, payload.source, payload.instanceId);
        if (!inst) return;

        let sound = null;
        let destLocation = zone;
        let destIndex = (index !== null) ? index : null;

        if (zone === 'monster') {
            if (!isMonsterType(inst.card)) {
                flashMessage('Only monsters can go in monster zones.');
                returnInstanceTo(player, payload.source, inst);
                return;
            }
            if (player.monsters[index]) {
                flashMessage('That monster zone is occupied.');
                returnInstanceTo(player, payload.source, inst);
                return;
            }
            inst.position = 'atk';
            inst.faceDown = false;
            player.monsters[index] = inst;
            sound = 'play_monster';
        } else if (zone === 'spell') {
            if (!isSpellType(inst.card)) {
                flashMessage('Only spells/traps go in S/T zones.');
                returnInstanceTo(player, payload.source, inst);
                return;
            }
            if (player.spells[index]) {
                flashMessage('That S/T zone is occupied.');
                returnInstanceTo(player, payload.source, inst);
                return;
            }
            inst.faceDown = false;
            player.spells[index] = inst;
            sound = 'play_spell';
        } else if (zone === 'field') {
            if (!isFieldSpell(inst.card)) {
                flashMessage('Only field spells go in the field zone.');
                returnInstanceTo(player, payload.source, inst);
                return;
            }
            if (player.field) {
                player.graveyard.push(player.field);
            }
            inst.faceDown = false;
            player.field = inst;
            sound = 'play_field';
        } else if (zone === 'graveyard') {
            player.graveyard.push(inst);
            sound = 'to_grave';
        } else if (zone === 'banished') {
            player.banished.push(inst);
            sound = 'banish';
        } else {
            returnInstanceTo(player, payload.source, inst);
            return;
        }
        if (sound) playSound(sound);
        renderAll();
        finishMoveAnim(animHandle, side, inst.instanceId, destLocation, destIndex);
    }

    function takeFromSource(player, source, instanceId) {
        if (source === 'hand') {
            const idx = player.hand.findIndex(i => i.instanceId === instanceId);
            if (idx < 0) return null;
            return player.hand.splice(idx, 1)[0];
        }
        if (source === 'extra') {
            const idx = player.extra.findIndex(i => i.instanceId === instanceId);
            if (idx < 0) return null;
            return player.extra.splice(idx, 1)[0];
        }
        if (source === 'monster') {
            for (let i = 0; i < player.monsters.length; i++) {
                if (player.monsters[i] && player.monsters[i].instanceId === instanceId) {
                    const inst = player.monsters[i];
                    player.monsters[i] = null;
                    return inst;
                }
            }
        }
        if (source === 'spell') {
            for (let i = 0; i < player.spells.length; i++) {
                if (player.spells[i] && player.spells[i].instanceId === instanceId) {
                    const inst = player.spells[i];
                    player.spells[i] = null;
                    return inst;
                }
            }
        }
        if (source === 'field') {
            if (player.field && player.field.instanceId === instanceId) {
                const inst = player.field;
                player.field = null;
                return inst;
            }
        }
        if (source === 'graveyard') {
            const idx = player.graveyard.findIndex(i => i.instanceId === instanceId);
            if (idx < 0) return null;
            return player.graveyard.splice(idx, 1)[0];
        }
        if (source === 'banished') {
            const idx = player.banished.findIndex(i => i.instanceId === instanceId);
            if (idx < 0) return null;
            return player.banished.splice(idx, 1)[0];
        }
        return null;
    }

    function returnInstanceTo(player, source, inst) {
        if (source === 'hand') player.hand.push(inst);
        else if (source === 'extra') player.extra.push(inst);
        else if (source === 'graveyard') player.graveyard.push(inst);
        else if (source === 'banished') player.banished.push(inst);
        renderAll();
    }

    /* ========== Context menu ========== */

    function showContextMenu(e, inst, side, location, index) {
        const menu = document.getElementById('cardContextMenu');
        const ul = menu.querySelector('ul');
        ul.innerHTML = '';
        const items = buildMenuItems(inst, side, location, index);
        items.forEach(item => {
            const li = document.createElement('li');
            li.textContent = item.label;
            li.addEventListener('click', () => {
                item.action();
                hideContextMenu();
                renderAll();
            });
            ul.appendChild(li);
        });
        menu.style.left = e.pageX + 'px';
        menu.style.top = e.pageY + 'px';
        menu.style.display = 'block';
    }

    function hideContextMenu() {
        document.getElementById('cardContextMenu').style.display = 'none';
    }

    function buildMenuItems(inst, side, location, index) {
        const items = [];
        const player = state[side];

        if (location === 'monster') {
            items.push({ label: inst.position === 'atk' ? 'Switch to Defense' : 'Switch to Attack', action: () => {
                inst.position = inst.position === 'atk' ? 'def' : 'atk';
                if (inst.position === 'atk') inst.faceDown = false;
                playSound('position');
            }});
            items.push({ label: inst.faceDown ? 'Flip Face-up' : 'Set Face-down (Defense)', action: () => {
                inst.faceDown = !inst.faceDown;
                if (inst.faceDown) inst.position = 'def';
                playSound('flip');
            }});
            items.push({ label: 'Send to Graveyard', action: () => {
                moveCard(side, inst.instanceId, 'to_grave', () => {
                    player.monsters[index] = null;
                    inst.faceDown = false;
                    player.graveyard.push(inst);
                }, 'graveyard', null);
            }});
            items.push({ label: 'Banish', action: () => {
                moveCard(side, inst.instanceId, 'banish', () => {
                    player.monsters[index] = null;
                    inst.faceDown = false;
                    player.banished.push(inst);
                }, 'banished', null);
            }});
            items.push({ label: 'Return to Hand', action: () => {
                moveCard(side, inst.instanceId, 'to_hand', () => {
                    player.monsters[index] = null;
                    inst.faceDown = false;
                    player.hand.push(inst);
                }, 'hand', null);
            }});
        } else if (location === 'spell') {
            items.push({ label: inst.faceDown ? 'Activate (Flip Up)' : 'Set Face-down', action: () => {
                inst.faceDown = !inst.faceDown;
                playSound('flip');
            }});
            items.push({ label: 'Send to Graveyard', action: () => {
                moveCard(side, inst.instanceId, 'to_grave', () => {
                    player.spells[index] = null;
                    inst.faceDown = false;
                    player.graveyard.push(inst);
                }, 'graveyard', null);
            }});
            items.push({ label: 'Banish', action: () => {
                moveCard(side, inst.instanceId, 'banish', () => {
                    player.spells[index] = null;
                    inst.faceDown = false;
                    player.banished.push(inst);
                }, 'banished', null);
            }});
        } else if (location === 'field') {
            items.push({ label: 'Send to Graveyard', action: () => {
                moveCard(side, inst.instanceId, 'to_grave', () => {
                    player.field = null;
                    inst.faceDown = false;
                    player.graveyard.push(inst);
                }, 'graveyard', null);
            }});
        } else if (location === 'hand') {
            if (isMonsterType(inst.card)) {
                items.push({ label: 'Set Face-down (Defense) — pick zone', action: () => {
                    const free = player.monsters.findIndex(m => m === null);
                    if (free < 0) { flashMessage('No free monster zone.'); return; }
                    moveCard(side, inst.instanceId, 'set_card', () => {
                        inst.faceDown = true;
                        inst.position = 'def';
                        removeFromHand(player, inst.instanceId);
                        player.monsters[free] = inst;
                    }, 'monster', free);
                }});
            } else if (isSpellType(inst.card)) {
                items.push({ label: 'Set Face-down', action: () => {
                    if (isFieldSpell(inst.card)) {
                        moveCard(side, inst.instanceId, 'set_card', () => {
                            if (player.field) player.graveyard.push(player.field);
                            inst.faceDown = true;
                            removeFromHand(player, inst.instanceId);
                            player.field = inst;
                        }, 'field', null);
                        return;
                    }
                    const free = player.spells.findIndex(s => s === null);
                    if (free < 0) { flashMessage('No free S/T zone.'); return; }
                    moveCard(side, inst.instanceId, 'set_card', () => {
                        inst.faceDown = true;
                        removeFromHand(player, inst.instanceId);
                        player.spells[free] = inst;
                    }, 'spell', free);
                }});
            }
            items.push({ label: 'Discard to Graveyard', action: () => {
                moveCard(side, inst.instanceId, 'to_grave', () => {
                    removeFromHand(player, inst.instanceId);
                    player.graveyard.push(inst);
                }, 'graveyard', null);
            }});
            items.push({ label: 'Banish', action: () => {
                moveCard(side, inst.instanceId, 'banish', () => {
                    removeFromHand(player, inst.instanceId);
                    player.banished.push(inst);
                }, 'banished', null);
            }});
        }
        return items;
    }

    function removeFromHand(player, instanceId) {
        const idx = player.hand.findIndex(i => i.instanceId === instanceId);
        if (idx >= 0) player.hand.splice(idx, 1);
    }

    /* ========== Pile viewer ========== */

    function openPileViewer(side, pile) {
        const titles = { graveyard: 'Graveyard', banished: 'Banished', deck: 'Deck', extra: 'Extra Deck' };
        document.getElementById('pileViewerTitle').textContent =
            (side === 'player' ? 'Your ' : "Opponent's ") + titles[pile];
        const list = state[side][pile];
        const container = document.getElementById('pileViewerContent');
        container.innerHTML = '';
        if (!list || list.length === 0) {
            container.innerHTML = '<p class="text-muted">Empty.</p>';
        } else {
            list.forEach(inst => {
                const el = document.createElement('div');
                el.className = 'pile-card';
                const img = document.createElement('img');
                img.src = `/images/${inst.card.id}.jpg`;
                img.onerror = function() { this.src = CARD_BACK; };
                img.alt = inst.card.name || '';
                img.title = inst.card.name || '';
                el.appendChild(img);
                if (side === 'player') {
                    el.style.cursor = 'pointer';
                    el.title = 'Click to return to hand';
                    el.addEventListener('click', () => {
                        const idx = list.findIndex(i => i.instanceId === inst.instanceId);
                        if (idx >= 0) {
                            const handle = startMoveAnimFromEl(el, side);
                            list.splice(idx, 1);
                            inst.faceDown = false;
                            state[side].hand.push(inst);
                            playSound('to_hand');
                            // Close the modal first so the hand is visible to fly to.
                            document.getElementById('pileViewer').style.display = 'none';
                            renderAll();
                            finishMoveAnim(handle, side, inst.instanceId, 'hand', null);
                        }
                    });
                }
                container.appendChild(el);
            });
        }
        document.getElementById('pileViewer').style.display = 'flex';
    }

    /* ========== Preview tooltip ========== */

    let previewTimer = null;
    function showPreview(inst) {
        clearTimeout(previewTimer);
        previewTimer = setTimeout(() => {
            const el = document.getElementById('cardPreview');
            const c = inst.card;
            el.innerHTML = `
                <div class="preview-name">${escapeHtml(c.name || '')}</div>
                <div class="preview-type">${escapeHtml(c.type || '')} ${c.race ? '· ' + escapeHtml(c.race) : ''} ${c.attribute ? '· ' + escapeHtml(c.attribute) : ''}</div>
                ${(c.atk !== null && c.atk !== undefined) ? `<div class="preview-stats">ATK ${c.atk} / DEF ${c.def ?? '-'}</div>` : ''}
                <div class="preview-desc">${escapeHtml(c.desc || '')}</div>`;
            el.style.display = 'block';
        }, 350);
    }

    function hidePreview() {
        clearTimeout(previewTimer);
        document.getElementById('cardPreview').style.display = 'none';
    }

    document.addEventListener('mousemove', (e) => {
        const el = document.getElementById('cardPreview');
        if (el.style.display !== 'none') {
            const x = Math.min(window.innerWidth - 360, e.pageX + 16);
            const y = Math.min(window.innerHeight - 280, e.pageY + 16);
            el.style.left = x + 'px';
            el.style.top = y + 'px';
        }
    });

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    /* ========== Misc UI ========== */

    function flashMessage(msg) {
        if (typeof showToast === 'function') showToast(msg, 'info');
        else console.log(msg);
    }

    /* ========== Wiring ========== */

    function setupZoneClicks() {
        document.querySelectorAll('.zone-deck').forEach(d => {
            d.addEventListener('click', () => {
                const side = d.dataset.side;
                if (side === 'player') drawCard('player', 1);
            });
            d.addEventListener('contextmenu', (e) => {
                e.preventDefault();
                const side = d.dataset.side;
                const menu = document.getElementById('cardContextMenu');
                const ul = menu.querySelector('ul');
                ul.innerHTML = '';
                [
                    { label: 'View Deck (top to bottom)', action: () => openPileViewer(side, 'deck') },
                    { label: 'Shuffle Deck', action: () => { shuffleDeck(side); renderAll(); } },
                    { label: 'Draw 1', action: () => drawCard(side, 1) },
                    { label: 'Draw 5', action: () => drawCard(side, 5) }
                ].forEach(item => {
                    const li = document.createElement('li');
                    li.textContent = item.label;
                    li.addEventListener('click', () => { item.action(); hideContextMenu(); });
                    ul.appendChild(li);
                });
                menu.style.left = e.pageX + 'px';
                menu.style.top = e.pageY + 'px';
                menu.style.display = 'block';
            });
        });

        document.querySelectorAll('.zone-graveyard, .zone-banished, .zone-extra').forEach(zoneEl => {
            zoneEl.addEventListener('click', () => {
                const side = zoneEl.dataset.side;
                const pile = zoneEl.dataset.zone;
                openPileViewer(side, pile);
            });
        });
    }

    function setupPhaseButtons() {
        document.querySelectorAll('.phase-btn[data-phase]').forEach(btn => {
            btn.addEventListener('click', () => {
                const phase = btn.dataset.phase;
                const idx = PHASES.indexOf(phase);
                if (idx >= 0) setPhase(idx);
            });
        });
        document.getElementById('nextPhaseBtn').addEventListener('click', nextPhase);
        document.getElementById('endTurnBtn').addEventListener('click', endTurn);
    }

    function setupLPButtons() {
        document.querySelectorAll('.lp-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const side = btn.dataset.target;
                const amount = parseInt(btn.dataset.amount, 10);
                state[side].lp = Math.max(0, state[side].lp + amount);
                renderLP();
                if (state[side].lp === 0) {
                    flashMessage(`${side === 'player' ? 'You' : 'Opponent'} reached 0 LP!`);
                }
            });
        });
    }

    function setupGlobalHandlers() {
        document.addEventListener('click', (e) => {
            const menu = document.getElementById('cardContextMenu');
            if (menu.style.display === 'block' && !menu.contains(e.target)) {
                hideContextMenu();
            }
        });
        document.getElementById('pileViewerClose').addEventListener('click', () => {
            document.getElementById('pileViewer').style.display = 'none';
        });
        document.getElementById('pileViewer').addEventListener('click', (e) => {
            if (e.target.id === 'pileViewer') {
                document.getElementById('pileViewer').style.display = 'none';
            }
        });
    }

    /* ========== Init ========== */

    function init() {
        setupDropTargets();
        setupZoneClicks();
        setupPhaseButtons();
        setupLPButtons();
        setupGlobalHandlers();
        // Opening hands
        drawCard('player', 5);
        drawCard('opponent', 5);
        renderAll();
    }

    document.addEventListener('DOMContentLoaded', init);
</script>

