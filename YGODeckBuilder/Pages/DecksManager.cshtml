@page
@using System.Web
@model YGODeckBuilder.Pages.DecksManager

@{
    ViewData["Title"] = "Decks Manager";
    var defaultNewDeckName = "new_deck_name";
}
<head>
    <link rel="stylesheet" href="~/css/decksManager.css">
    <script src="/js/decksManager.js"></script>
</head>

<h2 class="mb-4">Decks Manager</h2>

<div class="container">
    <div class="deck-menu">
        <div class="list-group-item d-flex justify-content-between align-items-center bg-dark border-light">
            <div class="btn-group" role="group" aria-label="Decks Menu">
                <button type="button" class="btn btn-success mr-1" id="btnNewDeck" onclick="showNewDeckInput('@defaultNewDeckName')">New</button>
                <button type="button" class="btn btn-success mr-1" id="btnLoadDeck" onclick="showLoadInput()">Load</button>
                <input type="file" id="deckFileInput" accept=".ydk" style="display:none" onchange="loadDeck(event)" />
                <a class="btn btn-primary mr-1" href="https://ygoprodeck.com/tournaments/top-archetypes/">Browse</a>
            </div>
        </div>
    </div>

    @if (Model.Decks.Any())
    {
        <div id="deckList" class="list-group bg-dark text-light">
            @foreach (var deck in Model.Decks)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center bg-dark border-light" data-deck-name="@deck.DeckName">
                    <a href="/DeckBuilder?DeckFileName=@deck.DeckName" class="text-white text-uppercase">@deck.DeckName</a>
                    <div class="btn-group" role="group" aria-label="Deck Actions">
                        <a class="btn btn-primary mr-1" href="/DeckBuilder?DeckFileName=@deck.DeckName">Edit</a>
                        <button type="button" class="btn btn-success mr-1" onclick="duplicateDeck('@deck.DeckName')">Duplicate</button>
                        <button type="button" class="btn btn-warning mr-1" onclick="showRenameModal('@deck.DeckName')">Rename</button>
                        <button type="button" class="btn btn-danger" onclick="showDeleteConfirm('@deck.DeckName')">Delete</button>
                    </div>
                </div>
            }
        </div>
        <div id="emptyDeckMessage" class="alert alert-warning" role="alert" style="display:none">
            No decks found. Please create a new deck.
        </div>
    }
    else
    {
        <div id="deckList" class="list-group bg-dark text-light" style="display:none"></div>
        <div id="emptyDeckMessage" class="alert alert-warning" role="alert">
            No decks found. Please create a new deck.
        </div>
    }
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1" role="dialog" aria-labelledby="renameModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="renameModalLabel">Rename Deck</h5>
                <button type="button" class="close text-light" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="text" id="renameInput" class="form-control" placeholder="New deck name" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="confirmRenameBtn">Rename</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete Deck</h5>
                <button type="button" class="close text-light" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete '<span id="deleteDeckNameDisplay"></span>'?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>
