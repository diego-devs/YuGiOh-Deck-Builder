@page
@using System.Web
@model YGODeckBuilder.Pages.DecksManager

@{
    ViewData["Title"] = "Decks Manager";
    var defaultNewDeckName = "new_deck_name";
}
<head>
    <link rel="stylesheet" href="~/css/decksManager.css">
    <script src="/js/decksManager.js"></script>
</head>

<h2 class="mb-4">Decks Manager</h2>

<div class="container">

    @* ── PERSONAL DECKS (logged-in users only) ── *@
    @if (Model.IsAuthenticated)
    {
        <div class="deck-section mb-4">
            <div class="deck-section-header d-flex justify-content-between align-items-center mb-2">
                <h5 class="deck-section-title">Your Decks</h5>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-success btn-sm mr-1" id="btnNewDeck" onclick="showNewDeckInput('@defaultNewDeckName')">+ New</button>
                    <button type="button" class="btn btn-success btn-sm mr-1" id="btnLoadDeck" onclick="showLoadInput()">Load .ydk</button>
                    <input type="file" id="deckFileInput" accept=".ydk" style="display:none" onchange="loadDeck(event)" />
                </div>
            </div>

            @if (Model.PersonalDecks.Any())
            {
                <div id="personalDeckList" class="list-group">
                    @foreach (var deck in Model.PersonalDecks)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center bg-dark border-light" data-deck-name="@deck.DeckName">
                            <a href="/DeckBuilder?DeckFileName=@deck.DeckName&personal=true" class="text-white text-uppercase">@deck.DeckName</a>
                            <div class="btn-group" role="group">
                                <a class="btn btn-primary btn-sm mr-1" href="/DeckBuilder?DeckFileName=@deck.DeckName&personal=true">Edit</a>
                                <button type="button" class="btn btn-success btn-sm mr-1" onclick="duplicateDeck('@deck.DeckName')">Duplicate</button>
                                <button type="button" class="btn btn-warning btn-sm mr-1" onclick="showRenameModal('@deck.DeckName')">Rename</button>
                                <button type="button" class="btn btn-danger btn-sm" onclick="showDeleteConfirm('@deck.DeckName')">Delete</button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small">No personal decks yet. Create one or fork a community deck below.</p>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary mb-4" style="background:rgba(255,255,255,0.05);border:1px solid rgba(125,90,255,0.25);color:#a0a0c8;">
            <a asp-page="/Account/Login" style="color:#9090d8;">Log in</a> to create and manage your own decks.
        </div>
    }

    @* ── COMMUNITY DECKS (visible to all) ── *@
    <div class="deck-section">
        <div class="deck-section-header mb-2">
            <h5 class="deck-section-title">Community Decks</h5>
        </div>

        @if (Model.CommunityDecks.Any())
        {
            <div id="communityDeckList" class="list-group">
                @foreach (var deck in Model.CommunityDecks)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center bg-dark border-light">
                        <span class="text-white text-uppercase">@deck.DeckName</span>
                        <div class="btn-group" role="group">
                            @if (Model.IsAuthenticated)
                            {
                                <button type="button" class="btn btn-outline-info btn-sm" onclick="forkDeck('@deck.DeckName')">Fork to My Decks</button>
                            }
                            else
                            {
                                <a class="btn btn-outline-secondary btn-sm" asp-page="/Account/Login">Login to Fork</a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted small">No community decks found.</p>
        }
    </div>

    @* hidden list for decksManager.js compatibility *@
    <div id="deckList" style="display:none"></div>
    <div id="emptyDeckMessage" style="display:none"></div>
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1" role="dialog" aria-labelledby="renameModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="renameModalLabel">Rename Deck</h5>
                <button type="button" class="close text-light" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="text" id="renameInput" class="form-control" placeholder="New deck name" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="confirmRenameBtn">Rename</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete Deck</h5>
                <button type="button" class="close text-light" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete '<span id="deleteDeckNameDisplay"></span>'?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>
