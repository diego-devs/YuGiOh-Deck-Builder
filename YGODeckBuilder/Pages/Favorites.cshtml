@page
@model YGODeckBuilder.Pages.FavoritesModel
@{
    ViewData["Title"] = "Favorites";
}
<style>
    .favorites-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .favorites-count {
        font-size: 0.9rem;
        color: #7070a0;
        font-family: 'Rajdhani', sans-serif;
    }

    /* Card tile grid */
    .fav-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 1rem;
    }

    .fav-tile {
        position: relative;
        background: linear-gradient(160deg, rgba(15, 12, 40, 0.96), rgba(30, 18, 58, 0.96));
        border: 1px solid rgba(125, 90, 255, 0.2);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

    .fav-tile:hover {
        border-color: rgba(125, 90, 255, 0.6);
        box-shadow: 0 0 18px rgba(100, 60, 200, 0.32);
    }

    .fav-tile a.tile-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .fav-tile img {
        width: 100%;
        display: block;
        transition: transform 0.25s ease;
    }

    .fav-tile:hover img {
        transform: scale(1.05);
    }

    .fav-tile-body {
        padding: 0.4rem 0.5rem 0.6rem;
    }

    .fav-tile-name {
        font-size: 0.72rem;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        color: #ddddf0;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .fav-tile-meta {
        font-size: 0.62rem;
        color: #7070a0;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fav-tile-price {
        font-size: 0.68rem;
        color: #90c0a0;
        margin-top: 2px;
    }

    /* Remove (unfavorite) button — top-right star */
    .btn-unfavorite {
        position: absolute;
        top: 5px;
        right: 5px;
        background: rgba(0, 0, 0, 0.65);
        border: none;
        color: #f5c518;
        font-size: 0.9rem;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        line-height: 1;
        transition: background 0.18s, transform 0.15s;
        z-index: 2;
    }

    .btn-unfavorite:hover {
        background: rgba(200, 40, 40, 0.82);
        transform: scale(1.18);
    }

    /* Removing animation */
    .fav-tile.removing {
        opacity: 0;
        transform: scale(0.82);
        transition: opacity 0.28s ease, transform 0.28s ease;
        pointer-events: none;
    }

    /* Empty state */
    .favorites-empty {
        text-align: center;
        padding: 4rem 1rem;
        color: #6060a0;
    }

    .favorites-empty .empty-star {
        font-size: 4rem;
        display: block;
        margin-bottom: 1rem;
        opacity: 0.35;
    }

    .favorites-empty p {
        font-size: 1rem;
        margin-bottom: 1.25rem;
    }
</style>

<div class="favorites-header">
    <h1>Favorites</h1>
    <span class="favorites-count" id="favCount">
        @Model.Favorites.Count card@(Model.Favorites.Count == 1 ? "" : "s")
    </span>
</div>

@if (Model.Favorites.Any())
{
    <div class="fav-grid" id="favGrid">
        @foreach (var fav in Model.Favorites)
        {
            <div class="fav-tile" data-konami-id="@fav.KonamiCardId">
                <button class="btn-unfavorite" title="Remove from favorites"
                        onclick="removeFavorite(this, @fav.KonamiCardId)">★</button>
                <a class="tile-link" href="/CardViewer?id=@fav.KonamiCardId">
                    <img src="@fav.ImageUrl" alt="@fav.Name" loading="lazy" />
                    <div class="fav-tile-body">
                        <div class="fav-tile-name">@fav.Name</div>
                        <div class="fav-tile-meta">
                            @(string.IsNullOrEmpty(fav.Attribute) ? fav.Type : $"{fav.Attribute} · {fav.Type}")
                        </div>
                        @if (!string.IsNullOrEmpty(fav.Price) && fav.Price != "0.00")
                        {
                            <div class="fav-tile-price">$@fav.Price</div>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
}

<div id="emptyState" class="favorites-empty" style="@(Model.Favorites.Any() ? "display:none" : "")">
    <span class="empty-star">★</span>
    <p>No favorites yet.</p>
    <a class="btn btn-primary" href="/MainPage">Browse cards</a>
</div>

@section Scripts {
<script>
    async function removeFavorite(btn, konamiId) {
        btn.disabled = true;
        try {
            const response = await fetch(`/api/favorites/${konamiId}`, { method: 'DELETE' });
            if (!response.ok) {
                showToast('Could not remove favorite.', 'error');
                btn.disabled = false;
                return;
            }

            const tile = btn.closest('.fav-tile');
            tile.classList.add('removing');
            setTimeout(() => {
                tile.remove();
                updateCount();
            }, 300);

            showToast('Removed from favorites.', 'success');
        } catch {
            showToast('Network error.', 'error');
            btn.disabled = false;
        }
    }

    function updateCount() {
        const remaining = document.querySelectorAll('.fav-tile').length;
        const countEl = document.getElementById('favCount');
        if (countEl) countEl.textContent = `${remaining} card${remaining === 1 ? '' : 's'}`;
        if (remaining === 0) document.getElementById('emptyState').style.display = '';
    }
</script>
}
